# App
NEXT_PUBLIC_APP_URL=https://perpackage-cafe24-file-upload-app.vercel.app

# Cafe24 Developers
CAFE24_MALL_ID=peerl
CAFE24_CLIENT_ID=your-cafe24-client-id
CAFE24_CLIENT_SECRET=your-cafe24-client-secret
CAFE24_REDIRECT_URI=https://perpackage-cafe24-file-upload-app.vercel.app/api/cafe24/auth/callback
CAFE24_SCOPES=mall.read_application,mall.read_product,mall.read_category,mall.read_community
CAFE24_API_VERSION=2024-06-01

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin access
ADMIN_ACCESS_PASSWORD=
ADMIN_SESSION_SECRET=

# Naver Object Storage (S3 compatible)
NAVER_ACCESS_KEY=your-naver-access-key
NAVER_SECRET_KEY=your-naver-secret-key
NAVER_OBJECT_STORAGE_ENDPOINT=https://kr.object.ncloudstorage.com
NAVER_OBJECT_STORAGE_BUCKET=your-bucket-name
NAVER_REGION=kr-standard

# Upload limits for phase 1 test page
UPLOAD_MAX_FILE_SIZE_MB=10
